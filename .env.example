# 環境変数設定例
# このファイルをコピーして .dev.vars として保存してください
# 本番環境では wrangler secret put コマンドを使用

# === アルゴスAPI設定 ===
# アルゴスAPIを有効にする場合は true に設定
ARGOS_API_ENABLED=false

# アルゴスAPIキー
# 取得方法: https://argos-api-example.com/dashboard/api-keys
ARGOS_API_KEY=your_argos_api_key_here

# アルゴスAPIエンドポイント（通常は変更不要）
ARGOS_API_URL=https://api.argos-example.com/v1

# === Stripe決済設定（将来実装） ===
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# === その他の外部API設定 ===
# 必要に応じて追加
